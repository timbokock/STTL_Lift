	Panel_3_Led_Up				AT %Q*  : BOOL; // Panel Level 3 - Led Up
	Panel_3_Led_Down			AT %Q*  : BOOL; // Panel Level 3 - Led Down
	Panel_3_BCD_Bit				AT %Q* 	: ARRAY[0..3] OF BOOL; // Panel Level 3- BCD Bit 0..3
	
	
	Door_4_SensorOpen			AT %I*	: BOOL;	// Door level 4 open
	Door_4_SensorClosed  		AT %I*	: BOOL; // Door level 4 closed
	Door_4_SensorActive			AT %I*	: BOOL; // Door level 4 sensor active
	Door_4_MotorOpen			AT %Q* 	: BOOL; // Motor level 4 - Open
	Door_4_MotorClose			AT %Q* 	: BOOL; // Motor level 4 - Close
	
