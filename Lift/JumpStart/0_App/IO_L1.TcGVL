	Control_Manual					AT %I*	: BOOL; // Mode: Manual
	Control_Automatic				AT %I*	: BOOL; // Mode: Automatic
	Control_Reset					AT %I*	: BOOL; // Reset
	Control_Start					AT %I*	: BOOL; // Start
	Control_EmergencyStopActive 	AT %I*	: BOOL; // Emergency stop active
