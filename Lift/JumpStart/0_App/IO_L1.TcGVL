	Panel_2_Led_Down			AT %Q*  : BOOL; // Panel Level 2 - Led Down
	Panel_2_BCD_Bit				AT %Q* 	: ARRAY[0..3] OF BOOL; // Panel Level 2- BCD Bit 0..3
	
	Door_3_SensorOpen			AT %I*	: BOOL;	// Door level 3 open
	Door_3_SensorClosed  		AT %I*	: BOOL; // Door level 3 closed
	Door_3_SensorActive			AT %I*	: BOOL; // Door level 3 sensor active
