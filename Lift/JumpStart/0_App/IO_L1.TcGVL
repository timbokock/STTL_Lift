  <GVL Name="IO_L1" Id="{a8d7390b-068e-40d9-8df5-8d1aff7e7470}">
    <Declaration><![CDATA[{attribute 'qualified_only'}
VAR_GLOBAL
	LiftAxis					: AXIS_REF;
	
