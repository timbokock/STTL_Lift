	Control_LiftAxisReference		AT %I*  : BOOL; // Lift reference sensor bottom
	Control_Firealarm				AT %I*  : BOOL; // Fire alarm signal
	
	Control_LED_Yellow				AT %Q*	: BOOL; // LED Yellow 
