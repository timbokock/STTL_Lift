  <POU Name="FB_Logik_FIFO" Id="{d52812a5-2086-4671-8327-67350c374281}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Logik_FIFO IMPLEMENTS ITF_Fahrlogik
